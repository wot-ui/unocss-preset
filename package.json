{
  "name": "@wot-ui/unocss-preset",
  "type": "module",
  "version": "0.0.1-beta.1",
  "packageManager": "pnpm@10.25.0",
  "description": "专为 wot-ui 打造的 UnoCSS 预设，提供开箱即用的主题变量映射与原子化类名。",
  "license": "MIT",
  "homepage": "https://github.com/wot-ui/unocss-preset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wot-ui/unocss-preset.git"
  },
  "bugs": "https://github.com/wot-ui/unocss-preset/issues",
  "keywords": [
    "unocss",
    "preset",
    "wot-ui",
    "design-tokens"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:playground": "pnpm --dir playground build:h5",
    "dev": "tsdown --watch",
    "dev:playground": "pnpm --dir playground dev:h5",
    "lint": "eslint --fix",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "typecheck": "tsc",
    "typecheck:playground": "pnpm --dir playground type-check",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "unocss": ">=0.66.0"
  },
  "dependencies": {
    "@unocss/core": "catalog:unocss"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tinyexec": "catalog:testing",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "vitest-package-exports": "catalog:testing",
    "yaml": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  }
}
